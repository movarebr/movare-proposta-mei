<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MOVARE — Assessoria para MEI</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream: #F5F0EA;
    --dark: #0F1208;
    --dark-mid: #181E10;
    --green: #3A5A2A;
    --green-light: #6A9A50;
    --accent: #8BAD5A;
    --accent-light: #AACC72;
    --muted: #7A8570;
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--cream); overflow-x: hidden; }

  /* ── HERO ── */
  .hero { 
    min-height: 100vh; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    text-align: center; 
    position: relative; 
    padding: 60px 24px; 
    overflow: hidden; 
    /* Degradê Verde Escuro */
    background: radial-gradient(ellipse 80% 60% at 50% 0%, #202e15 0%, var(--dark) 70%);
  }
  
  /* Textura sobre o Degradê */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    /* SVG na cor verde (--accent) */
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%238BAD5A' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }
  
  .hero > * { position: relative; z-index: 1; }

  .hero-badge { display: inline-block; border: 1px solid rgba(139,173,90,0.5); color: var(--accent-light); font-size: 11px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase; padding: 8px 20px; border-radius: 100px; margin-bottom: 36px; background: rgba(139,173,90,0.08); backdrop-filter: blur(5px); animation: fadeUp 0.8s ease both; }
  .hero-logo { margin-bottom: 24px; animation: fadeUp 0.8s 0.1s ease both; }
  .hero-logo svg { width: 52px; height: 52px; opacity: 0.9; }
  .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(42px, 8vw, 88px); font-weight: 300; line-height: 1.05; color: var(--cream); margin-bottom: 12px; animation: fadeUp 0.8s 0.2s ease both; }
  .hero h1 em { font-style: italic; color: var(--accent-light); }
  .hero-sub { font-family: 'Cormorant Garamond', serif; font-size: clamp(16px,3vw,22px); font-weight: 300; font-style: italic; color: rgba(170,204,114,0.85); margin-bottom: 48px; animation: fadeUp 0.8s 0.3s ease both; }
  .hero-divider { width: 60px; height: 1px; background: linear-gradient(to right,transparent,var(--accent),transparent); margin: 0 auto 48px; animation: fadeUp 0.8s 0.35s ease both; }
  .hero-intro { max-width: 560px; font-size: 16px; line-height: 1.8; color: rgba(245,240,234,0.7); margin-bottom: 52px; animation: fadeUp 0.8s 0.4s ease both; }
  .hero-cta { display: inline-flex; align-items: center; gap: 10px; background: linear-gradient(135deg, var(--accent), #5A7D32); color: var(--dark); font-size: 14px; font-weight: 500; letter-spacing: 1px; text-transform: uppercase; padding: 16px 36px; border-radius: 4px; text-decoration: none; transition: all 0.3s ease; animation: fadeUp 0.8s 0.5s ease both; }
  .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 20px 40px rgba(139,173,90,0.3); }
  .hero-scroll { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; animation: fadeUp 1s 1s ease both; }
  .hero-scroll span { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
  .scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--accent), transparent); animation: scrollAnim 2s ease infinite; }

  section { padding: 100px 24px; }
  .container { max-width: 1000px; margin: 0 auto; }
  .section-label { font-size: 11px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
  .section-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--accent); }
  .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(32px,5vw,52px); font-weight: 300; line-height: 1.15; color: var(--cream); margin-bottom: 20px; }
  .section-title em { font-style: italic; color: var(--accent-light); }
  .section-body { font-size: 16px; line-height: 1.85; color: rgba(245,240,234,0.65); max-width: 620px; }

  .sobre { background: var(--dark); }
  .nichos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 64px; }
  .nicho-card { background: var(--dark-mid); padding: 32px; text-align: center; transition: background 0.3s; position: relative; overflow: hidden; }
  .nicho-card:hover { background: #202810; }
  .nicho-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, var(--accent), transparent); transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; }
  .nicho-card:hover::after { transform: scaleX(1); }
  .nicho-card-icon { font-size: 36px; margin-bottom: 12px; }
  .nicho-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 400; color: var(--cream); margin-bottom: 8px; }
  .nicho-card p { font-size: 13px; line-height: 1.6; color: rgba(245,240,234,0.7); }

  .stats { background: linear-gradient(135deg, #0c1208, var(--dark)); border-top: 1px solid rgba(139,173,90,0.15); border-bottom: 1px solid rgba(139,173,90,0.15); padding: 80px 24px; }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(139,173,90,0.1); }
  .stat-item { background: var(--dark); padding: 40px 24px; text-align: center; }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 52px; font-weight: 300; color: var(--accent-light); line-height: 1; margin-bottom: 8px; }
  .stat-label { font-size: 12px; letter-spacing: 1px; color: var(--muted); text-transform: uppercase; }

  .servicos { background: var(--dark-mid); }
  .servicos-list { margin-top: 64px; display: flex; flex-direction: column; gap: 2px; }
  .servico-item { display: flex; align-items: center; gap: 32px; padding: 32px 40px; background: var(--dark); transition: background 0.3s; }
  .servico-item:hover { background: #0c1008; }
  .servico-num { font-family: 'Cormorant Garamond', serif; font-size: 42px; font-weight: 300; color: rgba(139,173,90,0.2); min-width: 56px; line-height: 1; }
  .servico-content h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; color: var(--cream); margin-bottom: 6px; }
  .servico-content p { font-size: 14px; color: rgba(245,240,234,0.75); line-height: 1.7; }
  .servico-icon { margin-left: auto; color: var(--accent); font-size: 20px; opacity: 0.6; }

  .pacotes { background: var(--dark); }
  .pacotes-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; margin-top: 64px; }
  .pacote-card { background: var(--dark-mid); display: flex; flex-direction: column; transition: transform 0.3s ease; position: relative;}
  .pacote-card:hover { transform: translateY(-4px); }
  .pacote-card.destaque { background: #141c0c; border: 1px solid rgba(139,173,90,0.3); }
  .pacote-tag { position: absolute; top: 20px; right: 20px; background: var(--accent); color: var(--dark); font-size: 10px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; padding: 5px 12px; border-radius: 100px; }
  .pacote-header { padding: 40px 36px 28px; border-bottom: 1px solid rgba(139,173,90,0.1); }
  .pacote-tier { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
  .pacote-name { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 300; color: var(--cream); margin-bottom: 20px; }
  .pacote-price { display: flex; align-items: baseline; gap: 6px; }
  .price-currency { font-size: 14px; color: var(--muted); }
  .price-value { font-family: 'Cormorant Garamond', serif; font-size: 48px; font-weight: 300; color: var(--cream); line-height: 1; }
  .price-period { font-size: 13px; color: var(--muted); }
  .pacote-body { padding: 32px 36px; flex: 1; }
  .pacote-body h4 { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 20px; }
  .pacote-features { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
  .pacote-features li { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; color: rgba(245,240,234,0.75); line-height: 1.5; }
  .pacote-features li::before { content: '◆'; color: var(--accent); font-size: 8px; margin-top: 5px; flex-shrink: 0; }
  .pacote-footer { padding: 0 36px 36px; }
  .btn-proposta { display: block; text-align: center; background: transparent; border: 1px solid rgba(139,173,90,0.4); color: var(--accent-light); font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; padding: 16px; text-decoration: none; transition: all 0.3s; border-radius: 2px; }
  .btn-proposta:hover { background: var(--accent); border-color: var(--accent); color: var(--dark); }
  .pacote-card.destaque .btn-proposta { background: linear-gradient(135deg, var(--accent), #5A7D32); border-color: transparent; color: var(--dark); font-weight: 500; }

  .passos { background: var(--dark-mid); }
  .passos-list { margin-top: 64px; position: relative; }
  .passos-list::before { content: ''; position: absolute; left: 28px; top: 0; bottom: 0; width: 1px; background: linear-gradient(to bottom, var(--accent), transparent); }
  .passo-item { display: flex; gap: 40px; padding: 0 0 48px 0; position: relative; }
  .passo-dot { width: 56px; height: 56px; border-radius: 50%; background: var(--dark); border: 1px solid rgba(139,173,90,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--accent); position: relative; z-index: 1; }
  .passo-content { padding-top: 12px; flex: 1; }
  .passo-content h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; color: var(--cream); margin-bottom: 8px; }
  .passo-content p { font-size: 14px; color: rgba(245,240,234,0.75); line-height: 1.7; }

  /* ── CTA FINAL ── */
  .cta-final { 
    text-align: center; 
    border-top: 1px solid rgba(139,173,90,0.15); 
    padding: 120px 24px; 
    position: relative; 
    overflow: hidden; 
    /* Degradê Verde Escuro vindo de baixo */
    background: radial-gradient(ellipse 80% 60% at 50% 100%, #202e15 0%, var(--dark) 70%);
  }
  
  /* Textura sobre o CTA */
  .cta-final::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%238BAD5A' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .cta-final > * { position: relative; z-index: 1; }
  .cta-final h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px,6vw,72px); font-weight: 300; color: var(--cream); margin-bottom: 20px; line-height: 1.1; }
  .cta-final h2 em { font-style: italic; color: var(--accent-light); }
  .cta-final p { font-size: 16px; color: var(--muted); margin-bottom: 52px; max-width: 480px; margin-left: auto; margin-right: auto; }
  .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 52px; }
  .btn-whats { display: inline-flex; align-items: center; gap: 10px; background: #25D366; color: #fff; font-size: 14px; font-weight: 500; padding: 16px 32px; border-radius: 4px; text-decoration: none; transition: all 0.3s; }
  .btn-whats:hover { transform: translateY(-2px); box-shadow: 0 16px 32px rgba(37,211,102,0.25); }
  .btn-insta { display: inline-flex; align-items: center; gap: 10px; background: transparent; border: 1px solid rgba(139,173,90,0.4); color: var(--accent-light); font-size: 14px; font-weight: 500; padding: 16px 32px; border-radius: 4px; text-decoration: none; transition: all 0.3s; }
  .btn-insta:hover { background: rgba(139,173,90,0.1); border-color: var(--accent); }

  footer { background: #080c04; padding: 48px 24px; text-align: center; border-top: 1px solid rgba(139,173,90,0.08); }
  footer p { font-size: 13px; color: rgba(122,133,112,0.5); }
  footer strong { color: var(--accent); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes scrollAnim { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  @media (max-width: 768px) { .nichos-grid { grid-template-columns: 1fr 1fr; } .pacotes-grid { grid-template-columns: 1fr; } .stats-grid { grid-template-columns: repeat(2,1fr); } .passos-list::before { display: none; } }
</style>
</head>
